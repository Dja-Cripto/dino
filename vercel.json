{
  "version": 2,
  "cleanUrls": true,
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/music/(.*)", "dest": "/music/$1" },
    { "src": "/script.js", "dest": "/script.js" },
    { "src": "/design.js", "dest": "/design.js" },
    { "src": "/style.css", "dest": "/style.css" },
    { "src": "/scores.json", "dest": "/scores.json" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
